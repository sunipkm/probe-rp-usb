# RP2040/RP2350 — app mode (stdio USB, default PID 0x0009)
SUBSYSTEM=="usb", ATTRS{idVendor}=="2e8a", GROUP="plugdev", MODE="0666"
# RP2040/RP2350 — BOOTSEL / picoboot (PID 0x000f)
SUBSYSTEM=="usb", ATTRS{idVendor}=="2e8a", ATTRS{idProduct}=="000f", GROUP="plugdev", MODE="0666"
# Custom VID fallback (0xC0DE)
SUBSYSTEM=="usb", ATTRS{idVendor}=="c0de", GROUP="plugdev", MODE="0666"
